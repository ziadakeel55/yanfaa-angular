{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "experimentalServices": {
    "yanfaa-backend": {
      "type": "web",
      "routePrefix": "/",
      "framework": "angular",
      "buildCommand": "pip install -r server/requirements.txt"
    }
  }
}
